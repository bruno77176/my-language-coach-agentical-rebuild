{
  "extends": [
    "expo/tsconfig.base",
    "@language-coach/config/tsconfig.base.json"
  ],
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", "types/**/*.d.ts", "nativewind-env.d.ts"],
  "exclude": ["node_modules", "vitest.config.ts"]
}
