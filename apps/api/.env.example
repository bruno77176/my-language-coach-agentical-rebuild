NODE_ENV=development
PORT=3000

# From Supabase project settings → API Keys → "Publishable and secret API keys" tab
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR-PUBLISHABLE-KEY
SUPABASE_SECRET_KEY=sb_secret_YOUR-SECRET-KEY

# From Supabase project settings → Database → Connection string.
# Use the SESSION POOLER (port 5432, username `postgres.<project-ref>`) — the direct
# `db.<project-ref>.supabase.co` host is IPv6-only on new projects and won't resolve from
# IPv4-only networks. The pooler hostname is `aws-0-<region>` or `aws-1-<region>`
# depending on which Supavisor cluster the project is provisioned on (check the dashboard).
DATABASE_URL=postgresql://postgres.YOUR-PROJECT:YOUR-PASSWORD@aws-1-YOUR-REGION.pooler.supabase.com:5432/postgres

# From Sentry project → Settings → Client Keys (DSN)
SENTRY_DSN=https://YOUR-DSN@oNNNNNN.ingest.sentry.io/NNN

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-proj-...

# Deepgram (https://console.deepgram.com)
DEEPGRAM_API_KEY=...

# ElevenLabs (https://elevenlabs.io/app/settings/api-keys)
ELEVENLABS_API_KEY=...

# RevenueCat webhook secret — gates POST /v1/billing/revenuecat.
# Generate a long random value (>=20 chars), paste it into the RevenueCat
# dashboard under Webhooks → Authorization, and set it here + in Fly secrets.
REVENUECAT_WEBHOOK_SECRET=...
