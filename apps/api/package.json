{
  "name": "@language-coach/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc --noEmit",
    "start": "node --import tsx src/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node --env-file=.env --import tsx src/db/run-migrations.ts",
    "db:verify": "node --env-file=.env --import tsx src/db/verify-migrations.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@deepgram/sdk": "^5.1.0",
    "@elevenlabs/elevenlabs-js": "^2.46.0",
    "@hono/node-server": "^2.0.2",
    "@language-coach/shared": "workspace:*",
    "@sentry/node": "^10.52.0",
    "@supabase/supabase-js": "^2.105.4",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.18",
    "openai": "^6.37.0",
    "pino": "^10.3.1",
    "postgres": "^3.4.9",
    "tsx": "^4.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@language-coach/config": "workspace:*",
    "@types/node": "^25.6.2",
    "@vitest/coverage-v8": "^4.1.5",
    "drizzle-kit": "^0.31.10",
    "pino-pretty": "^13.1.3",
    "typescript": "^5.7.2",
    "vitest": "^4.1.5"
  }
}
